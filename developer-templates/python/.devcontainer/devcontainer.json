{
  "name": "Capital Group — Python Project",
  "image": "ghcr.io/ashrujitpal1/devcontainer-feature-cg/claude-base:1.0.0",
  "features": {
    "ghcr.io/ashrujitpal1/devcontainer-feature-cg/python:1": {
      "version": "3.12"
    },
    "ghcr.io/ashrujitpal1/devcontainer-feature-cg/approved-ide-tools-vscode:1": {},
    "ghcr.io/ashrujitpal1/devcontainer-feature-cg/otel-collector:1": {}
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "eamodio.gitlens",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.black-formatter",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "claudeCode.environmentVariables": [
          { "name": "CLAUDE_CODE_USE_BEDROCK",          "value": "1" },
          { "name": "AWS_REGION",                       "value": "us-east-1" },
          { "name": "AWS_PROFILE",                      "value": "default" },
          { "name": "ANTHROPIC_DEFAULT_SONNET_MODEL",   "value": "us.anthropic.claude-sonnet-4-6" }
        ],
        "claudeCode.disableLoginPrompt": true
      }
    }
  },
  "containerEnv": {
    "NODE_OPTIONS":               "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR":          "/root/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "CLAUDE_CODE_USE_BEDROCK":    "1",
    "AWS_REGION":                 "us-east-1",
    "AWS_PROFILE":                "default",
    "SECURITY_POLICY_S3_BUCKET":  "capital-group-claude-policies",
    "SECURITY_POLICY_S3_PREFIX":  "latest",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_SERVICE_NAME":          "claude-code",
    "OTEL_TRACES_EXPORTER":       "otlp",
    "OTEL_METRICS_EXPORTER":      "otlp",
    "OTEL_LOGS_EXPORTER":         "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL":  "5000",
    "OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT": "true",
    "OTEL_RESOURCE_ATTRIBUTES":   "deployment.environment=dev,service.namespace=capital-group"
  },
  "mounts": [
    "source=cg-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=cg-claude-config-${devcontainerId},target=/root/.claude,type=volume",
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "postStartCommand": "/usr/local/bin/sync-security-policy.sh",
  "waitFor": "postStartCommand",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  }
}
