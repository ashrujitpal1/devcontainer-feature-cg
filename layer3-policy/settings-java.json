{
  "permissions": {
    "allow": [
      "Bash(java:*)",
      "Bash(javac:*)",
      "Bash(mvn:*)",
      "Bash(gradle:*)",
      "Bash(gradlew:*)",
      "Bash(mvnw:*)"
    ]
  },
  "fileSystemIsolation": {
    "allowedPaths": [
      "/workspace",
      "/tmp",
      "/usr/lib/jvm",
      "/root/.m2",
      "/root/.gradle"
    ]
  }
}
