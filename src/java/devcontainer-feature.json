{
  "name": "Java (Capital Group Approved)",
  "id": "java",
  "version": "1.0.0",
  "description": "Installs an approved Java JDK version with Maven and/or Gradle",
  "options": {
    "version": {
      "type": "string",
      "enum": ["21", "17", "11"],
      "default": "21",
      "description": "Java JDK version to install"
    },
    "installMaven": {
      "type": "boolean",
      "default": true,
      "description": "Install Apache Maven"
    },
    "installGradle": {
      "type": "boolean",
      "default": false,
      "description": "Install Gradle"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.java",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test"
      ]
    }
  },
  "installsAfter": []
}
